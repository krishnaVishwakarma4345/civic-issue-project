rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMasterAdmin() {
      return isAuthenticated() &&
        userDoc().role == 'master-admin';
    }

    function isDepartmentAdmin() {
      return isAuthenticated() &&
        userDoc().role == 'department-admin';
    }

    function isAnyAdmin() {
      return isMasterAdmin() || isDepartmentAdmin();
    }

    function departmentCategory() {
      return userDoc().adminCategory;
    }

    function canReadIssueByRole() {
      return resource.data.citizenId == request.auth.uid ||
        isMasterAdmin() ||
        (isDepartmentAdmin() && resource.data.category == departmentCategory());
    }

    function isValidRole(role) {
      return role == 'citizen' || role == 'department-admin' || role == 'master-admin';
    }

    // ─── Users Collection ─────────────────────────────────────
    match /users/{userId} {
      // Read: own doc or admin
      allow read: if isAuthenticated() && (isOwner(userId) || isAnyAdmin());

      // Create: only own document, role must be citizen
      allow create: if isAuthenticated() &&
        isOwner(userId) &&
        request.resource.data.role == 'citizen' &&
        request.resource.data.email is string &&
        request.resource.data.name is string;

      // Update: own doc but cannot change role
      allow update: if isAuthenticated() &&
        isOwner(userId) &&
        request.resource.data.role == resource.data.role;

      // Delete: nobody
      allow delete: if false;
    }

    // ─── Issues Collection ────────────────────────────────────
    match /issues/{issueId} {
      // Read: own issues or admin
      allow read: if isAuthenticated() &&
        canReadIssueByRole();

      // Create: authenticated citizens only
      allow create: if isAuthenticated() &&
        request.resource.data.citizenId == request.auth.uid &&
        request.resource.data.status == 'reported' &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 5 &&
        request.resource.data.title.size() <= 100 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() >= 20 &&
        request.resource.data.description.size() <= 1000;

      // Update: admin can update all fields, citizen can only update images
      allow update: if isAuthenticated() && (
        (
          isDepartmentAdmin() &&
          resource.data.category == departmentCategory()
        ) ||
        (resource.data.citizenId == request.auth.uid &&
         request.resource.data.status == resource.data.status)
      );

      // Delete: admin only
      allow delete: if isDepartmentAdmin() &&
        resource.data.category == departmentCategory();
    }

    // ─── Deny everything else ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
